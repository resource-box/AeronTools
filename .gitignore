## ---------------------------------------------------------------------------
## 공통 무시 파일
## ---------------------------------------------------------------------------

# 로그 파일
*.log

# 구성 파일
*.ini

## ---------------------------------------------------------------------------
## Java / IntelliJ 의 일반적인 무시 파일
## ---------------------------------------------------------------------------

# Compiled class file
*.class

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# 패키지 파일
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash 로그
hs_err_pid*
replay_pid*

# IntelliJ 모듈 및 프로젝트 파일 (IDE가 자동 생성하므로 보통 제외)
*.iml
*.ipr
*.iws

# 컴파일된 아웃풋 디렉토리 (IntelliJ 기본)
out/

# 사용하는 빌드 도구에 따른 결과물 (해당하는 경우 주석 해제하여 사용)
# build/   # Gradle
# .gradle/ # Gradle 로컬 캐시
# target/  # Maven

# 플러그인 및 기타 임시 파일
.idea_modules/
atlassian-ide-plugin.xml
com_crashlytics_export_strings.xml
crashlytics.properties

# Windows 썸네일 및 Mac 시스템 파일
Thumbs.db
ehthumbs.db
.DS_Store

## ---------------------------------------------------------------------------
## .NET Framework / Visual Studio 의 일반적인 무시 파일
## ---------------------------------------------------------------------------

# 빌드 결과물 (Binaries)
[Bb]in/
[Oo]bj/
/out/

# Visual Studio 폴더 및 사용자 전용 파일
.vs/
*.user
*.userosscache
*.sln.docstates
*.suo
*.vssscc

# NuGet 패키지 폴더
packages/
*.nupkg
# (단, 패키지 복원을 위한 아래 파일들은 예외 처리할 수 있습니다)
# !packages/build/
# !packages/repositories.config

# 테스트 결과 (Test Results)
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx
*.testsettings

# 프로파일링 및 진단 파일
*.psess
*.vsp
*.vspx
*.sap

# 게시(Publish) 관련 임시 파일
*.Publish.xml
*.pubxml
*.pubxml.user
app.publish/

# ReSharper / JetBrains Rider 관련 파일
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user
.idea/

# Windows 썸네일 및 시스템 파일
Thumbs.db
ehthumbs.db
.DS_Store

# 암호화/키 파일 (주의: 인증서나 키가 유출되지 않도록 확인)
*.pfx
*.snk